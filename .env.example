# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings -> API). Both values are safe to expose publicly; the
# database is protected by Row Level Security (see supabase/schema.sql).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
